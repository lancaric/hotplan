## HotPlan environment variables (example)
## Copy to `.env` (do not commit `.env`).

# VoIP device credentials (recommended)
VOIP_USERNAME=
VOIP_PASSWORD=

# Web admin login (recommended)
HOTPLAN_ADMIN_USERNAME=admin
HOTPLAN_ADMIN_PASSWORD=change-me

# Optional alternative names also supported by ConfigLoader
# HOTPLAN_VOIP_USERNAME=
# HOTPLAN_VOIP_PASSWORD=
